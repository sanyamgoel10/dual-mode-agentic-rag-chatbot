# Chat LLM — set one provider
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# Embeddings (always Google)
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=3072
CHUNK_SIZE_WORDS=300
CHUNK_OVERLAP_WORDS=30
# GOOGLE_API_KEY already set above

# Vector store — create index with dimension=768, metric=cosine
PINECONE_API_KEY=...
PINECONE_INDEX=emb-chatbot

# Tracing (LangSmith reads LANGCHAIN_* prefixed vars)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=emb-chatbot

# App
CURRENT_DATE=2026-06-15
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Local dev paths (Docker uses /app/... defaults, override here for local)
DATABASE_PATH=./data/orders.db
ORDERS_CSV_PATH=../database/orders.csv
